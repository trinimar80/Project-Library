# Dockerfile.web - Para la aplicación web de Tarea 7
FROM python:3.11-slim

# Evitar que Python genere archivos .pyc y permitir logs en tiempo real
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# Instalar dependencias del sistema para PostgreSQL
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    locales \
    && rm -rf /var/lib/apt/lists/*

# Configurar el locale ru_RU.UTF-8 (consistente con tu configuración)
RUN sed -i -e 's/# ru_RU.UTF-8 UTF-8/ru_RU.UTF-8 UTF-8/' /etc/locale.gen && \
    locale-gen
ENV LANG ru_RU.UTF-8
ENV LC_ALL ru_RU.UTF-8

# Crear usuario no-root para seguridad
RUN useradd --create-home app_user

WORKDIR /app

# Copiar requirements e instalar dependencias
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copiar archivos de la aplicación web
COPY web_app.py .
COPY templates/ ./templates/

# Crear directorio para logs
RUN mkdir -p /app/logs && chown -R app_user:app_user /app

# Cambiar a usuario no-root (buena práctica de seguridad)
USER app_user

# Puerto para Flask
EXPOSE 5000

# Comando para iniciar la aplicación
CMD ["python", "web_app.py"]
